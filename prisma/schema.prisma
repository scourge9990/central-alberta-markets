generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  username        String    @unique
  password_hash   String
  is_admin        Boolean   @default(false)
  is_vendor      Boolean   @default(false)
  vendor_name    String?
  phone         String?
  subscription_tier String   @default("free")
  stripe_customer_id String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  alerts         Alert[]
  subscriptions Subscription[]
}

model Alert {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user      User     @relation(fields: [user_id], references: [id])
  keyword   String
  active    Boolean  @default(true)
  created_at DateTime @default(now())
}

model Subscription {
  id                Int       @id @default(autoincrement())
  user_id           Int
  user              User      @relation(fields: [user_id], references: [id])
  stripe_sub_id      String    @unique
  status            String
  tier              String
  current_period_end DateTime
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
}

model Market {
  id            Int       @id @default(autoincrement())
  name          String
  slug          String    @unique
  address       String
  city          String
  province      String    @default("AB")
  postal_code   String
  lat           Float
  lng           Float
  website       String?
  facebook     String?
  description  String?
  schedule     Json
  is_active    Boolean   @default(true)
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  vendors     Vendor[]
  items       MarketItem[]
}

model Vendor {
  id          Int       @id @default(autoincrement())
  market_id   Int
  market     Market    @relation(fields: [market_id], references: [id])
  name       String
  description String?
  contact    String?
  website   String?
  facebook  String?
  items     String
  active    Boolean  @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  market_items MarketItem[]
}

model MarketItem {
  id          Int       @id @default(autoincrement())
  market_id   Int
  market     Market    @relation(fields: [market_id], references: [id])
  vendor_id   Int?
  vendor     Vendor?   @relation(fields: [vendor_id], references: [id])
  name       String
  category   String?
  price      String?
  unit       String?
  available  Boolean   @default(true)
  updated_at  DateTime   @default(now())

  @@index([market_id])
  @@index([vendor_id])
}

model WhatsFresh {
  id         Int      @id @default(autoincrement())
  title      String
  description String
  image      String?
  vendor_id  Int?
  market_id  Int
  active    Boolean   @default(true)
  created_at DateTime  @default(now())
}
